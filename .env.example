# PrismGateway — provider API keys
# Copy to .env and fill in your keys. Never commit .env.

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
GEMINI_API_KEY=AIza...

# xAI
XAI_API_KEY=xai-...

# Cohere
COHERE_API_KEY=...

# DeepSeek
DEEPSEEK_API_KEY=...

# Kimi (Moonshot)
MOONSHOT_API_KEY=...

# AWS Bedrock (optional — uses IAM if not set)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
