# .env.example - Copy to .env and fill in your values

# Optional: Provider credentials (can also be configured dynamically)
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GEMINI_API_KEY=your-gemini-key-here
XAI_API_KEY=xai-your-key-here
CLAUDE_API_KEY=k-ant-your-claude-key-here (could be the same as anthropics api key)

# AWS Bedrock (optional)
AWS_ACCESS_KEY_ID=...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1
# AWS credentials are expected to be provided via environment or IAM roles

# Optional: Database URL (auto-set in docker-compose, override if needed)
# DATABASE_URL=postgresql://router:router@localhost:5432/router?sslmode=disable

# Optional: Server configuration (override defaults)
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8080

# Optional: OpenTelemetry (optional)
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=llm-gateway

# Admin API Key (required for admin endpoints and dashboard)
# Used by frontend to authenticate with backend admin API
# Format: rk_<env>_<random-base64>
# Generate with: openssl rand -base64 32 | tr '+/' '-_' | tr -d '='
# Example: rk_live_67nC4PU1qXdJITukn_k8m3ab_Yr_fJiHC2ad6dOvGRw
# Generate new one using: ./scripts/generate-admin-key.sh
GATEWAY_ADMIN_API_KEY=rk_live_your-random-key-here-generate-with-script-below

# Optional: Backend URL for frontend (auto-set in docker-compose)
# Inside Docker: http://gateway:8080
# Local dev: http://localhost:5555
# GATEWAY_BASE_URL=http://gateway:8080

# Optional: Emergency admin token (X-Admin-Token header, backend only)
# ADMIN_TOKEN=your-secure-admin-token-here


# Conversation log encryption
# Active key version used for newly written encrypted conversation logs
LOG_ENC_ACTIVE_VERSION=v1

# Base64-encoded 32-byte key for AES-256-GCM
# Example generation:
#   openssl rand -base64 32
LOG_ENC_KEY_V1=your-base64-32-byte-key-here

# If conversation logging encryption is enabled in runtime and these are missing,
# conversation log writes will fail.
# For key rotation, define additional versions:
# LOG_ENC_KEY_V2=...

# Alerts
# Mail
RESEND_API_KEY: ${RESEND_API_KEY:-}