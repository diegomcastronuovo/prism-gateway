# PrismGateway — environment variables
# Copy to .env and fill in your values. Never commit .env.

# Admin API key — used by the gateway and the frontend admin UI
# Change this before deploying. Must match in gateway + frontend.
GATEWAY_ADMIN_API_KEY=change-me-admin-key

# Provider API keys (fill in the ones you want to use)

# OpenAI
OPENAI_API_KEY=sk-...

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini
GEMINI_API_KEY=AIza...

# xAI
XAI_API_KEY=xai-...

# Cohere
COHERE_API_KEY=...

# DeepSeek
DEEPSEEK_API_KEY=...

# Kimi (Moonshot)
MOONSHOT_API_KEY=...

# AWS Bedrock (optional — uses IAM if not set)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
